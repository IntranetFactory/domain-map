{"ts":"2026-05-29T08:11:28.619Z","log_type":"request","exit_code":4,"error":"Error: (PGRST102) Empty or invalid json","pgrst_code":"PGRST102","duration_ms":1097,"mcp_ms":365,"jwt":"eyJhbGciOiJFZERTQSIsImtpZCI6ImZERmV2RzQ5TDV1Y3BWdUx0Z1RqS2NKSEFQMmVGa3F6In0..Q42jeu-XgqlzNdy0lzeDv63LGx1foGZvhuQ7XywduWYZp0rEzGsQXymeaAziIS-t9gyIcx7HRzc6Uaymd_w-Ag","cli":["bun","B:/~BUN/root/semantius-windows-arm64.exe","call","crud","postgrestRequest","{\"method\":\"POST\",\"path\":\"/data_objects\",\"body\":[{\"data_object_name\":\"okr_key_results\",\"singular_label\":\"Key Result\",\"plural_label\":\"Key Results\",\"description\":\"Measurable result attached to an okr_objective. The unit of scoring on OKR programs — vendors universally model KR as first-class (Asana, Monday, ClickUp, Workfront).\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"okr_check_ins\",\"singular_label\":\"OKR Check-in\",\"plural_label\":\"OKR Check-ins\",\"description\":\"Periodic status update on an okr_objective or key_result during the active cycle. Cadence-of-record (weekly/bi-weekly) for OKR programs. May discuss individual performance — flagged as personal content.\",\"kind\":\"domain_owned\",\"has_personal_content\":true},{\"data_object_name\":\"work_dependencies\",\"singular_label\":\"Work Dependency\",\"plural_label\":\"Work Dependencies\",\"description\":\"Typed dependency between two work_items: predecessor/successor with type (FS finish-to-start, SS start-to-start, FF finish-to-finish, SF start-to-finish). Backs the WORK-DEPS-SCHED capability. Modeled by Asana, Monday, ClickUp, Workfront, Smartsheet.\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"work_milestones\",\"singular_label\":\"Milestone\",\"plural_label\":\"Milestones\",\"description\":\"Zero-duration gate within a work_project marking a meaningful transition. Distinct from a regular work_item by gate semantics (passed/missed). Asana, Monday, ClickUp, Workfront, Smartsheet all model.\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"work_approval_steps\",\"singular_label\":\"Approval Step\",\"plural_label\":\"Approval Steps\",\"description\":\"Single approval gate on a work_item or work_project, performed by a designated approver. Belongs to a work_approval_chain. Per-step states: pending / approved / rejected / expired.\",\"kind\":\"domain_owned\",\"has_single_approver\":true},{\"data_object_name\":\"work_approval_chains\",\"singular_label\":\"Approval Chain\",\"plural_label\":\"Approval Chains\",\"description\":\"Ordered or parallel set of work_approval_steps gating a work_item or work_project transition. Backs the APPROVAL-WORKFLOW capability (cross-cutting; this is the WORK-MGMT realization).\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"work_user_workloads\",\"singular_label\":\"Workload\",\"plural_label\":\"Workloads\",\"description\":\"Per-user, per-period sum of allocated effort on work_items, with capacity ceiling. Backs the WORK-CAPACITY capability. Continuous-numeric, not state-driven. May expose individual workload.\",\"kind\":\"domain_owned\",\"has_personal_content\":true},{\"data_object_name\":\"work_custom_fields\",\"singular_label\":\"Custom Field\",\"plural_label\":\"Custom Fields\",\"description\":\"User-defined field attached to a work_project or workspace, typed (text, number, date, select, etc.). Applies to all work_items in scope. Monday columns / Asana custom fields / ClickUp custom fields / Workfront / Smartsheet column types.\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"work_custom_field_values\",\"singular_label\":\"Custom Field Value\",\"plural_label\":\"Custom Field Values\",\"description\":\"Per-work_item value for a work_custom_field. Junction-style master: tuple (work_item, work_custom_field, value). Monday column_values, Asana custom_field_values, Smartsheet cells.\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"work_sections\",\"singular_label\":\"Section\",\"plural_label\":\"Sections\",\"description\":\"Container within a work_project that groups work_items for board/list views. Asana sections / Monday groups / ClickUp statuses-as-columns / Workfront statuses / Smartsheet parent rows.\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"work_project_templates\",\"singular_label\":\"Project Template\",\"plural_label\":\"Project Templates\",\"description\":\"Reusable work_project blueprint with seeded sections, items, custom fields, and automations. Universal across all 5 flagships; central to enterprise rollout patterns.\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"work_task_templates\",\"singular_label\":\"Task Template\",\"plural_label\":\"Task Templates\",\"description\":\"Reusable work_item blueprint with seeded assignee role, due-date offset, subtasks, and custom field defaults. Used for recurring or templated work creation.\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"work_tags\",\"singular_label\":\"Tag\",\"plural_label\":\"Tags\",\"description\":\"Free-form label attached to work_items for cross-cutting categorization (priority, theme, status). Many-to-many to work_items via work_item_tags.\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"work_item_tags\",\"singular_label\":\"Item Tag Assignment\",\"plural_label\":\"Item Tag Assignments\",\"description\":\"Junction master between work_items and work_tags. Carries no qualifier of its own; existence asserts the tag is applied.\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"work_item_comments\",\"singular_label\":\"Item Comment\",\"plural_label\":\"Item Comments\",\"description\":\"Threaded comment on a work_item. Asana stories / Monday updates / ClickUp comments / Workfront updates / Smartsheet conversations. May include personal or sensitive content.\",\"kind\":\"domain_owned\",\"has_personal_content\":true},{\"data_object_name\":\"work_item_attachments\",\"singular_label\":\"Item Attachment\",\"plural_label\":\"Item Attachments\",\"description\":\"File or external link attached to a work_item. May reference embedded content or platform-managed storage.\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"work_forms\",\"singular_label\":\"Form\",\"plural_label\":\"Forms\",\"description\":\"Structured intake form definition: schema (fields, validation), target project, routing rules. Asana Forms, Monday Forms, ClickUp Forms, Workfront Request Queues, Smartsheet Forms.\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"work_form_submissions\",\"singular_label\":\"Form Submission\",\"plural_label\":\"Form Submissions\",\"description\":\"Submitted instance of a work_form. Carries field values, submitter, timestamp. Converts to a work_item via routing rules. May contain personal content from form fields (requester name/email).\",\"kind\":\"domain_owned\",\"has_personal_content\":true}],\"headers\":{\"Prefer\":\"return=representation\"}}"]}
