{"ts":"2026-05-24T10:15:09.171Z","log_type":"request","exit_code":4,"error":"Error: (PGRST102) Empty or invalid json","pgrst_code":"PGRST102","duration_ms":1004,"mcp_ms":328,"jwt":"eyJhbGciOiJFZERTQSIsImtpZCI6ImZERmV2RzQ5TDV1Y3BWdUx0Z1RqS2NKSEFQMmVGa3F6In0..wQ73ursMF20FK-buRShcVotKOul8u89egDj_I51evnE_2IhgwwH019_OswrpTtDOyuh16uLgUkiuReKAmo6WAA","cli":["bun","B:/~BUN/root/semantius-windows-arm64.exe","call","crud","postgrestRequest","{\"method\":\"POST\",\"path\":\"/data_objects\",\"body\":[{\"data_object_name\":\"inv_stock_items\",\"singular_label\":\"Stock Item\",\"plural_label\":\"Stock Items\",\"description\":\"Inventory-scoped item record: SKU, unit of measure, lot/serial-controlled flag, ABC/XYZ class, default cost method (FIFO, LIFO, weighted-average), weight, and dimensions. INV-MGMT-mastered for standalone deployments; embedded-masters `commerce_products` when B2C-COMM is canonical.\",\"kind\":\"domain_owned\",\"notes\":\"Config-shape master. SKU is created and edited inline through admin UI. No per-state permissions needed beyond create/edit/delete; lifecycle states are not modeled per Rule #12 config-shape exemption.\"},{\"data_object_name\":\"inv_stock_locations\",\"singular_label\":\"Stock Location\",\"plural_label\":\"Stock Locations\",\"description\":\"INV-MGMT's finer-grain location catalog: warehouse, store, bin, zone, or hub. Defers to OMS `inventory_locations` (canonical) when present; deployable standalone otherwise.\",\"kind\":\"domain_owned\",\"notes\":\"Config-shape master. Locations are authored once and edited rarely; no workflow.\"},{\"data_object_name\":\"inv_stock_balances\",\"singular_label\":\"Stock Balance\",\"plural_label\":\"Stock Balances\",\"description\":\"Per-item by per-location quantity record: on_hand, reserved, in_transit, available_for_allocation. Real-time maintained by stock_movements; not directly edited.\",\"kind\":\"domain_owned\",\"notes\":\"Derived state, not workflow. Maintained by `inv_stock_movements` posting; no lifecycle states modeled.\"},{\"data_object_name\":\"inv_stock_movements\",\"singular_label\":\"Stock Movement\",\"plural_label\":\"Stock Movements\",\"description\":\"Append-only event ledger of inventory transactions: receipt, issue, transfer-in, transfer-out, adjustment-positive, adjustment-negative. Underlies stock_balances; posted movements are immutable.\",\"kind\":\"domain_owned\",\"has_submit_lock\":true,\"notes\":\"Submit-lock applies: a posted movement is immutable; reversal is a new compensating movement, not an edit.\"},{\"data_object_name\":\"inv_stock_transfers\",\"singular_label\":\"Stock Transfer\",\"plural_label\":\"Stock Transfers\",\"description\":\"Inter-location transfer header with lines: source location, destination location, requested-by user, status (requested, approved, in_transit, received, discrepancy, reconciled), expected arrival date.\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"inv_cycle_counts\",\"singular_label\":\"Cycle Count\",\"plural_label\":\"Cycle Counts\",\"description\":\"Scheduled or ad-hoc inventory count session: location, item-filter scope (ABC class, last-counted-before, all), assigned counter, status (scheduled, counting, variance_review, posted), per-line variances.\",\"kind\":\"domain_owned\",\"has_submit_lock\":true,\"has_single_approver\":true,\"notes\":\"Single-approver pattern: variance review is gated by a designated approver who signs off on the adjustment before posting.\"},{\"data_object_name\":\"inv_inventory_lots\",\"singular_label\":\"Inventory Lot\",\"plural_label\":\"Inventory Lots\",\"description\":\"INV-MGMT-scoped lot or batch identifier: lot_code, item, supplier, manufacture_date, expiry_date, originating receipt. Distinct from FDS `traceability_lots` (FSMA-204 food-traceability scope).\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"inv_serialized_units\",\"singular_label\":\"Serialized Unit\",\"plural_label\":\"Serialized Units\",\"description\":\"Individually-tracked unit with a unique serial: item, current location, current status (in_stock, reserved, issued, returned, scrapped), warranty_start.\",\"kind\":\"domain_owned\"},{\"data_object_name\":\"inv_reorder_rules\",\"singular_label\":\"Reorder Rule\",\"plural_label\":\"Reorder Rules\",\"description\":\"Item by location replenishment policy: reorder_point, reorder_quantity, safety_stock, lead_time_days, preferred_supplier, auto_generate_po flag.\",\"kind\":\"domain_owned\",\"notes\":\"Config-shape master. Authored by inventory planners; no workflow gates.\"},{\"data_object_name\":\"inv_kit_definitions\",\"singular_label\":\"Kit Definition\",\"plural_label\":\"Kit Definitions\",\"description\":\"Bill-of-kit for sellable bundles: parent item, list of component items with quantities, assembly_required flag (vs. explode-at-order).\",\"kind\":\"domain_owned\",\"notes\":\"Config-shape master. Kit BOMs are authored by merchandisers; no workflow.\"}]}"]}
